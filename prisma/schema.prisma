generator client {
  provider        = "prisma-client"
  output          = "../packages/common-types/src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, citext]
}

/// NOTE: All models use explicit IDs (no @default(uuid())) to enforce deterministic UUIDs.
/// This project syncs data between dev and prod - random UUIDs cause sync failures.
/// Application code MUST provide IDs using generators from deterministicUuid.ts.
/// See CLAUDE.md "Deterministic UUIDs Required" section.
model User {
  id                    String                     @id @db.Uuid
  discordId             String                     @unique @map("discord_id") @db.VarChar(20)
  username              String                     @db.VarChar(255)
  timezone              String                     @default("UTC") @db.VarChar(50)
  isSuperuser           Boolean                    @default(false) @map("is_superuser")
  /// NSFW verification status - required for DM interactions
  /// Auto-verified when user interacts with bot in an NSFW-marked channel
  nsfwVerified          Boolean                    @default(false) @map("nsfw_verified")
  nsfwVerifiedAt        DateTime?                  @map("nsfw_verified_at")
  defaultLlmConfigId    String?                    @map("default_llm_config_id") @db.Uuid
  /// Default-fallback: null means "use the personality/free vision-config cascade."
  defaultVisionConfigId String?                    @map("default_vision_config_id") @db.Uuid
  defaultTtsConfigId    String?                    @map("default_tts_config_id") @db.Uuid
  /// User-level STT provider override written by /voice stt set. When NULL,
  /// transcription derives from the user's default TTS provider (BYOK pairs
  /// like Mistral or ElevenLabs use the same engine for both directions),
  /// otherwise falls back to the self-hosted voice-engine.
  defaultSttProviderId  String?                    @map("default_stt_provider_id") @db.VarChar(20)
  defaultPersonaId      String                     @map("default_persona_id") @db.Uuid
  /// JSONB config cascade defaults (user tier). Validated against ConfigOverridesSchema at runtime.
  configDefaults        Json?                      @map("config_defaults")
  /// Release-notes DM master switch (default opt-in per owner spec; /notifications on|off).
  notifyEnabled         Boolean                    @default(true) @map("notify_enabled")
  /// Minimum changelog-derived release weight worth a DM. Default `major`
  /// (conservative — only breaking releases notify by default); users opt up
  /// to minor/patch via /notifications level.
  notifyLevel           NotifyLevel                @default(major) @map("notify_level")
  /// State machine: set once when the user first DELIBERATELY uses the bot
  /// (a real generation, or BYOK setup) and hasn't opted out; null for users
  /// the bot has only SEEN (extended-context participants get a provisioned
  /// row + default persona but never this). Release-DM eligibility requires
  /// it non-null, so passive bystanders are never in the blast radius.
  notifyOptedInAt       DateTime?                  @map("notify_opted_in_at")
  /// State machine: null unless notifications were AUTO-disabled after
  /// consecutive permanent release-DM failures (unreachable user); set
  /// alongside notifyEnabled=false by that path only. Cleared — with
  /// notifyEnabled restored — on the user's next deliberate use, or by any
  /// explicit /notifications update (explicit choice supersedes
  /// infrastructure history). Distinguishes infrastructure-disabled from
  /// user-opted-out; a user-chosen opt-out always has this null.
  notifyAutoDisabledAt  DateTime?                  @map("notify_auto_disabled_at")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")
  releaseDeliveries     ReleaseDeliveryLog[]
  feedbackSubmissions   UserFeedback[]
  apiKeys               UserApiKey[]
  credentials           UserCredential[]
  importJobs            ImportJob[]
  exportJobs            ExportJob[]
  usageLogs             UsageLog[]
  channelSettings       ChannelSettings[]
  adminSettingsUpdates  AdminSettings[]
  defaultLlmConfig      LlmConfig?                 @relation("UserDefaultLlmConfig", fields: [defaultLlmConfigId], references: [id], onDelete: SetNull)
  defaultVisionConfig   LlmConfig?                 @relation("UserDefaultVisionConfig", fields: [defaultVisionConfigId], references: [id], onDelete: SetNull)
  defaultTtsConfig      TtsConfig?                 @relation("UserDefaultTtsConfig", fields: [defaultTtsConfigId], references: [id], onDelete: SetNull)
  defaultPersona        Persona?                   @relation("UserDefaultPersona", fields: [defaultPersonaId], references: [id], onDelete: Restrict)
  ownedLlmConfigs       LlmConfig[]                @relation("LlmConfigOwner")
  ownedTtsConfigs       TtsConfig[]                @relation("TtsConfigOwner")
  ownedPersonalities    Personality[]              @relation("PersonalityOwner")
  personalityOwners     PersonalityOwner[]
  ownedPersonas         Persona[]                  @relation("PersonaOwner")
  personalityConfigs    UserPersonalityConfig[]
  personaHistoryConfigs UserPersonaHistoryConfig[]
  personalityAliases    PersonalityAlias[]         @relation("UserAliases")

  @@index([discordId])
  @@index([defaultLlmConfigId])
  @@index([defaultVisionConfigId])
  @@index([defaultTtsConfigId])
  @@index([defaultPersonaId])
  @@map("users")
}

/// Tracks API usage per user for monitoring, billing, and abuse prevention.
/// Even with BYOK, we track usage to prevent infrastructure abuse.
model UsageLog {
  id          String   @id @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  provider    String   @db.VarChar(20)
  model       String   @db.VarChar(255)
  tokensIn    Int      @map("tokens_in")
  tokensOut   Int      @map("tokens_out")
  requestType String   @map("request_type") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([provider]) // For admin queries filtering by provider across all users
  @@index([userId, createdAt])
  @@index([userId, provider])
  @@index([userId, provider, createdAt]) // For per-provider usage queries with date range
  @@map("usage_logs")
}

/// Global admin settings for bot-wide defaults.
/// Singleton row - only one row should exist (enforced by application code).
/// Replaces the old key-value BotSettings model with proper typed columns.
model AdminSettings {
  id                          String   @id @db.Uuid
  updatedBy                   String?  @map("updated_by") @db.Uuid
  /// JSONB config cascade defaults (admin tier). Validated against ConfigOverridesSchema at runtime.
  configDefaults              Json?    @map("config_defaults")
  /// JSONB owner-only operational settings (non-cascading; quota budgets, feature flags,
  /// fallback models). Validated against SystemSettingsSchema at runtime. NULL until the
  /// boot seed pass populates it; readers fall back to per-key registry seed constants.
  /// Unknown keys are PRESERVED on read-merge-write (rolling-deploy clobber protection).
  systemSettings              Json?    @map("system_settings")
  /// Default-fallback: the global (paid) default config for the chat slot. NULL means
  /// "no admin-set chat default" — the resolver cascade falls through to the hardcoded floor.
  globalDefaultLlmConfigId    String?  @map("global_default_llm_config_id") @db.Uuid
  /// Default-fallback: the global (paid) default config for the vision slot. NULL means
  /// "no admin-set vision default" — vision resolution falls through to the hardcoded floor.
  globalDefaultVisionConfigId String?  @map("global_default_vision_config_id") @db.Uuid
  /// Default-fallback: the free-tier default config for the chat slot (the guest/no-BYOK LLM
  /// fallback). NULL means "no free chat default" — resolution falls through to the floor.
  freeDefaultLlmConfigId      String?  @map("free_default_llm_config_id") @db.Uuid
  /// Default-fallback: the free-tier default config for the vision slot. NULL means
  /// "no free vision default" — resolution falls through to the floor.
  freeDefaultVisionConfigId   String?  @map("free_default_vision_config_id") @db.Uuid
  /// Default-fallback: the global (paid) default TTS config. NULL means "no admin-set TTS
  /// default" — presentational (badge/ordering) + delete-guard; sits in no resolution tier.
  globalDefaultTtsConfigId    String?  @map("global_default_tts_config_id") @db.Uuid
  /// Default-fallback: the free-tier default TTS config (tier 4 of TTS resolution). NULL
  /// means "no free TTS default" — resolution falls through to the hardcoded Kyutai floor.
  freeDefaultTtsConfigId      String?  @map("free_default_tts_config_id") @db.Uuid
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  updatedByUser             User?      @relation(fields: [updatedBy], references: [id])
  globalDefaultLlmConfig    LlmConfig? @relation("AdminGlobalDefaultLlmConfig", fields: [globalDefaultLlmConfigId], references: [id], onDelete: SetNull)
  globalDefaultVisionConfig LlmConfig? @relation("AdminGlobalDefaultVisionConfig", fields: [globalDefaultVisionConfigId], references: [id], onDelete: SetNull)
  freeDefaultLlmConfig      LlmConfig? @relation("AdminFreeDefaultLlmConfig", fields: [freeDefaultLlmConfigId], references: [id], onDelete: SetNull)
  freeDefaultVisionConfig   LlmConfig? @relation("AdminFreeDefaultVisionConfig", fields: [freeDefaultVisionConfigId], references: [id], onDelete: SetNull)
  globalDefaultTtsConfig    TtsConfig? @relation("AdminGlobalDefaultTtsConfig", fields: [globalDefaultTtsConfigId], references: [id], onDelete: SetNull)
  freeDefaultTtsConfig      TtsConfig? @relation("AdminFreeDefaultTtsConfig", fields: [freeDefaultTtsConfigId], references: [id], onDelete: SetNull)

  @@map("admin_settings")
}

/// Encrypted API keys for BYOK (Bring Your Own Key) support.
/// Uses AES-256-GCM encryption with separate columns for iv, content, and tag.
model UserApiKey {
  id         String    @id @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  provider   String    @default("openrouter") @db.VarChar(20)
  iv         String    @db.VarChar(32)
  content    String    @db.Text
  tag        String    @db.VarChar(32)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastUsedAt DateTime? @map("last_used_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@map("user_api_keys")
}

model Persona {
  id                    String                     @id @db.Uuid
  name                  String                     @db.Citext
  description           String?
  content               String
  preferredName         String?                    @map("preferred_name") @db.VarChar(255)
  pronouns              String?                    @db.VarChar(100)
  ownerId               String                     @map("owner_id") @db.Uuid
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")
  conversationHistory   ConversationHistory[]
  memories              Memory[]
  memoryFacts           MemoryFact[]
  owner                 User                       @relation("PersonaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  usersWithAsDefault    User[]                     @relation("UserDefaultPersona")
  shapesPersonaMappings ShapesPersonaMapping[]
  personalityConfigs    UserPersonalityConfig[]
  historyConfigs        UserPersonaHistoryConfig[] @relation("personaHistoryConfigs")

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("personas")
}

model SystemPrompt {
  id            String        @id @db.Uuid
  name          String        @db.VarChar(255)
  description   String?
  content       String
  isDefault     Boolean       @default(false) @map("is_default")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  personalities Personality[]

  @@index([isDefault])
  @@map("system_prompts")
}

model LlmConfig {
  id                                String                           @id @db.Uuid
  name                              String                           @db.Citext
  description                       String?
  ownerId                           String                           @map("owner_id") @db.Uuid
  isGlobal                          Boolean                          @default(false) @map("is_global")
  provider                          String                           @default("openrouter") @db.VarChar(20)
  model                             String                           @db.VarChar(255)
  /// JSONB field for provider-specific parameters (temperature, topP, topK, etc.)
  /// See AdvancedParamsSchema in common-types for validation
  advancedParameters                Json?                            @map("advanced_parameters")
  contextWindowTokens               Int                              @default(131072) @map("context_window_tokens")
  createdAt                         DateTime                         @default(now()) @map("created_at")
  updatedAt                         DateTime                         @updatedAt @map("updated_at")
  owner                             User                             @relation("LlmConfigOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  personalitiesUsingAsDefault       PersonalityDefaultConfig[]
  personalitiesUsingAsVisionDefault PersonalityVisionDefaultConfig[]
  userPersonalityConfigs            UserPersonalityConfig[]          @relation("UserPersonalityLlmConfig")
  userPersonalityVisionConfigs      UserPersonalityConfig[]          @relation("UserPersonalityVisionConfig")
  usersWithAsDefault                User[]                           @relation("UserDefaultLlmConfig")
  usersWithAsVisionDefault          User[]                           @relation("UserDefaultVisionConfig")
  adminGlobalLlmDefault             AdminSettings[]                  @relation("AdminGlobalDefaultLlmConfig")
  adminGlobalVisionDefault          AdminSettings[]                  @relation("AdminGlobalDefaultVisionConfig")
  adminFreeLlmDefault               AdminSettings[]                  @relation("AdminFreeDefaultLlmConfig")
  adminFreeVisionDefault            AdminSettings[]                  @relation("AdminFreeDefaultVisionConfig")

  @@unique([ownerId, name], map: "llm_configs_owner_id_name_key")
  @@index([ownerId])
  @@index([isGlobal])
  @@map("llm_configs")
}

model PersonalityDefaultConfig {
  personalityId String      @id @unique @map("personality_id") @db.Uuid
  llmConfigId   String      @map("llm_config_id") @db.Uuid
  updatedAt     DateTime    @updatedAt @map("updated_at")
  llmConfig     LlmConfig   @relation(fields: [llmConfigId], references: [id], onDelete: Cascade)
  personality   Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)

  @@index([llmConfigId])
  @@map("personality_default_configs")
}

model PersonalityVisionDefaultConfig {
  personalityId String      @id @unique @map("personality_id") @db.Uuid
  llmConfigId   String      @map("llm_config_id") @db.Uuid
  updatedAt     DateTime    @updatedAt @map("updated_at")
  llmConfig     LlmConfig   @relation(fields: [llmConfigId], references: [id], onDelete: Cascade)
  personality   Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)

  @@index([llmConfigId])
  @@map("personality_vision_default_configs")
}

model TtsConfig {
  id                          String                        @id @db.Uuid
  name                        String                        @db.Citext
  description                 String?
  ownerId                     String                        @map("owner_id") @db.Uuid
  isGlobal                    Boolean                       @default(false) @map("is_global")
  isDefault                   Boolean                       @default(false) @map("is_default")
  /// Default config for guest mode (users without TTS configured). Only one should be true.
  /// Enforced by partial unique index: tts_configs_free_default_unique (WHERE is_free_default = true)
  isFreeDefault               Boolean                       @default(false) @map("is_free_default")
  /// Stable provider id — `'self-hosted' | 'elevenlabs' | 'mistral'`. Wider VarChar than
  /// LlmConfig's 20 to accommodate longer TTS provider names if added later.
  provider                    String                        @db.VarChar(40)
  /// Provider-specific model id (e.g. `'eleven_multilingual_v2'`, `'voxtral-mini-tts-2603'`).
  /// NULL for providers with no model dimension (e.g. self-hosted).
  modelId                     String?                       @map("model_id") @db.VarChar(255)
  /// JSONB for provider-specific knobs (stability, similarity, etc.). Validated by
  /// TtsAdvancedParamsSchema in common-types.
  advancedParameters          Json?                         @map("advanced_parameters")
  createdAt                   DateTime                      @default(now()) @map("created_at")
  updatedAt                   DateTime                      @updatedAt @map("updated_at")
  owner                       User                          @relation("TtsConfigOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  personalitiesUsingAsDefault PersonalityDefaultTtsConfig[]
  userPersonalityConfigs      UserPersonalityConfig[]       @relation("UserPersonalityTtsConfig")
  usersWithAsDefault          User[]                        @relation("UserDefaultTtsConfig")
  adminGlobalDefaultOf        AdminSettings[]               @relation("AdminGlobalDefaultTtsConfig")
  adminFreeDefaultOf          AdminSettings[]               @relation("AdminFreeDefaultTtsConfig")

  @@unique([ownerId, name], map: "tts_configs_owner_id_name_key")
  @@index([ownerId])
  @@index([isGlobal])
  @@index([isFreeDefault])
  @@map("tts_configs")
}

model PersonalityDefaultTtsConfig {
  personalityId String      @id @unique @map("personality_id") @db.Uuid
  ttsConfigId   String      @map("tts_config_id") @db.Uuid
  updatedAt     DateTime    @updatedAt @map("updated_at")
  ttsConfig     TtsConfig   @relation(fields: [ttsConfigId], references: [id], onDelete: Cascade)
  personality   Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)

  @@index([ttsConfigId])
  @@map("personality_default_tts_configs")
}

model Personality {
  id                     String  @id @db.Uuid
  name                   String  @db.VarChar(255)
  displayName            String? @map("display_name") @db.VarChar(255)
  slug                   String  @unique @db.VarChar(255)
  systemPromptId         String? @map("system_prompt_id") @db.Uuid
  ownerId                String  @map("owner_id") @db.Uuid
  characterInfo          String  @map("character_info")
  personalityTraits      String  @map("personality_traits")
  personalityTone        String? @map("personality_tone")
  personalityAge         String? @map("personality_age")
  personalityAppearance  String? @map("personality_appearance")
  personalityLikes       String? @map("personality_likes")
  personalityDislikes    String? @map("personality_dislikes")
  conversationalGoals    String? @map("conversational_goals")
  conversationalExamples String? @map("conversational_examples")
  customFields           Json?   @map("custom_fields")
  errorMessage           String? @map("error_message")
  birthMonth             Int?    @map("birth_month")
  birthDay               Int?    @map("birth_day")
  birthYear              Int?    @map("birth_year")
  isPublic               Boolean @default(true) @map("is_public")
  /// When false (default), the character card fields (characterInfo,
  /// personalityTraits, tone/age/appearance/likes/dislikes, conversational
  /// goals/examples, errorMessage, customFields) are redacted to null for
  /// non-owners on the GET personality route; owner and bot-admin always see
  /// them. Gates definition visibility independently of `isPublic` (a public
  /// character can keep private internals). Never reverts to a prior value on
  /// its own — owner-controlled via the /character edit dashboard.
  definitionPublic       Boolean @default(false) @map("definition_public")
  voiceEnabled           Boolean @default(false) @map("voice_enabled")
  voiceSettings          Json?   @map("voice_settings")
  imageEnabled           Boolean @default(false) @map("image_enabled")
  imageSettings          Json?   @map("image_settings")
  avatarData             Bytes?  @map("avatar_data")
  voiceReferenceData     Bytes?  @map("voice_reference_data")
  voiceReferenceType     String? @map("voice_reference_type") @db.VarChar(50)
  /// JSONB config cascade defaults (personality tier). Validated against ConfigOverridesSchema at runtime.
  configDefaults         Json?   @map("config_defaults")

  createdAt               DateTime                        @default(now()) @map("created_at")
  updatedAt               DateTime                        @updatedAt @map("updated_at")
  channelSettings         ChannelSettings[]
  aliases                 PersonalityAlias[]
  conversationHistory     ConversationHistory[]
  memories                Memory[]
  memoryFacts             MemoryFact[]
  owner                   User                            @relation("PersonalityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  systemPrompt            SystemPrompt?                   @relation(fields: [systemPromptId], references: [id])
  defaultConfigLink       PersonalityDefaultConfig?
  defaultVisionConfigLink PersonalityVisionDefaultConfig?
  defaultTtsConfigLink    PersonalityDefaultTtsConfig?
  owners                  PersonalityOwner[]
  userConfigs             UserPersonalityConfig[]
  personaHistoryConfigs   UserPersonaHistoryConfig[]
  importJobs              ImportJob[]

  @@index([slug])
  @@index([ownerId])
  @@map("personalities")
}

model PersonalityOwner {
  personalityId String      @map("personality_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  role          String      @default("owner") @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  personality   Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([personalityId, userId])
  @@index([userId])
  @@index([personalityId])
  @@map("personality_owners")
}

/// Aliases for personalities (e.g., "lily" -> lilith, "sassy" -> sarcastic)
/// Enables users to reference personalities by multiple names.
///
/// Uniqueness is enforced by two PARTIAL unique indexes on lower(alias)
/// (global rows unique among globals; user rows unique per user) written by
/// hand in the migration — Prisma can't represent partial/functional unique
/// indexes, so there is deliberately NO @unique here; drift-ignore entries
/// keep Prisma from dropping them. Alias matching is case-insensitive
/// everywhere (resolver lowercases; deterministic ids seed from the
/// lowercased alias).
model PersonalityAlias {
  id            String      @id @db.Uuid
  alias         String      @db.VarChar(100)
  personalityId String      @map("personality_id") @db.Uuid
  /// Null = global tier (bot-owner-blessed; resolves for everyone, including
  /// the v2-migrated rows grandfathered at the 2026-07 tier split). Non-null
  /// = user-scoped tier: resolves ONLY for that user, checked before global
  /// rows in the resolver's alias step. Never flips after creation.
  userId        String?     @map("user_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  personality   Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  user          User?       @relation("UserAliases", fields: [userId], references: [id], onDelete: Cascade)

  @@index([personalityId])
  @@index([userId])
  @@map("personality_aliases")
}

/// User-specific overrides for a personality (persona, LLM config)
/// Note: STM epoch fields (lastContextReset) are in UserPersonaHistoryConfig,
/// which tracks per-persona history (user + personality + persona).
/// Per-(user, personality) overrides. Aggregates four orthogonal override
/// slices into one row: persona, LLM config, TTS config, and a configOverrides
/// JSON blob. Each slice is independently nullable because routes set them
/// independently: /preset override writes llmConfigId, /voice tts writes
/// ttsConfigId, /persona override writes personaId, and /channel context
/// writes configOverrides. The row's existence is the upsert anchor; nullability
/// of each slice means "no override for this slice on this (user, personality)."
/// State-machine-style pattern — null is meaningful per-field.
model UserPersonalityConfig {
  id              String   @id @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  personalityId   String   @map("personality_id") @db.Uuid
  /// Default-fallback: null means "use the user's default persona for this personality."
  personaId       String?  @map("persona_id") @db.Uuid
  /// Default-fallback: null means "use the user/personality LLM cascade."
  llmConfigId     String?  @map("llm_config_id") @db.Uuid
  /// Default-fallback: null means "use the user/personality vision-config cascade."
  visionConfigId  String?  @map("vision_config_id") @db.Uuid
  /// Default-fallback: null means "use the user/personality TTS cascade."
  ttsConfigId     String?  @map("tts_config_id") @db.Uuid
  /// Default-fallback: JSONB config cascade overrides (user+personality tier).
  /// Null means "no per-personality config-overrides for this user; fall through
  /// to user/global tier." Validated against ConfigOverridesSchema at runtime.
  configOverrides Json?    @map("config_overrides")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  llmConfig    LlmConfig?  @relation("UserPersonalityLlmConfig", fields: [llmConfigId], references: [id], onDelete: SetNull)
  visionConfig LlmConfig?  @relation("UserPersonalityVisionConfig", fields: [visionConfigId], references: [id], onDelete: SetNull)
  ttsConfig    TtsConfig?  @relation("UserPersonalityTtsConfig", fields: [ttsConfigId], references: [id], onDelete: SetNull)
  persona      Persona?    @relation(fields: [personaId], references: [id], onDelete: SetNull)
  personality  Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personalityId])
  @@index([userId])
  @@index([personalityId])
  @@map("user_personality_configs")
}

/// Per-persona history configuration (epoch tracking for memory commands)
/// This enables each persona to have independent conversation history cutoffs
/// See ADR-003 in docs/planning/SLASH_COMMAND_ARCHITECTURE.md
model UserPersonaHistoryConfig {
  id            String   @id @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  personalityId String   @map("personality_id") @db.Uuid
  personaId     String   @map("persona_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // STM Epoch System - Non-destructive conversation history filtering per-persona
  // Messages older than lastContextReset are excluded from AI context
  /// State machine: null = no clear epoch active (either never cleared, or
  /// undone after a first-time clear; full history visible). DateTime = clear
  /// is active; messages before this timestamp are hidden. The undo path
  /// writes `lastContextReset = previousContextReset`, which can be null when
  /// undoing a first-time clear — that's the canonical "no clear active" state
  /// for a row that exists. Do not tighten to NOT NULL; null is load-bearing.
  lastContextReset     DateTime? @map("last_context_reset")
  /// State machine: null = no prior epoch to restore (either no clear ever
  /// occurred, or the most recent undo consumed it). DateTime = a prior epoch
  /// exists; one undo would restore lastContextReset to this value. Cleared
  /// to null on every undo to prevent re-undoing the same operation.
  previousContextReset DateTime? @map("previous_context_reset")

  persona     Persona     @relation("personaHistoryConfigs", fields: [personaId], references: [id], onDelete: Cascade)
  personality Personality @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personalityId, personaId])
  @@index([userId])
  @@index([personalityId])
  @@index([personaId])
  @@map("user_persona_history_configs")
}

model ConversationHistory {
  id               String         @id @db.Uuid
  channelId        String         @map("channel_id") @db.VarChar(20)
  guildId          String?        @map("guild_id") @db.VarChar(20) // Null for DMs
  personalityId    String         @map("personality_id") @db.Uuid
  personaId        String         @map("persona_id") @db.Uuid
  role             String         @db.VarChar(20)
  content          String
  tokenCount       Int?           @map("token_count") // Cached token count (null for old messages)
  discordMessageId String[]       @default([]) @map("discord_message_id") // Discord snowflake IDs for chunked messages (deduplication)
  /// Structured metadata for the message (referenced messages, attachments, etc.)
  /// Separates semantic content (in 'content') from contextual data
  /// See MessageMetadata interface in common-types for schema
  messageMetadata  Json?          @default("{}") @map("message_metadata")
  /// Soft delete timestamp - message excluded from context when set
  /// Used for opportunistic sync when Discord message is deleted
  deletedAt        DateTime?      @map("deleted_at")
  /// Last edit detected timestamp - updated during opportunistic sync
  /// when Discord message content differs from stored content
  editedAt         DateTime?      @map("edited_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  persona          Persona        @relation(fields: [personaId], references: [id], onDelete: Cascade)
  personality      Personality    @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  pendingMemory    PendingMemory?

  @@index([channelId, personalityId, createdAt(sort: Desc)])
  @@index([personaId, personalityId, createdAt(sort: Desc)])
  @@index([discordMessageId])
  // No GIN index on messageMetadata: nothing queries it by JSONB containment
  // (it's only ever SELECTed whole and property-accessed in app code), so the
  // index was pure write-overhead — its pending-list flushes stalled inserts
  // multi-second under load (the gateway query_timeout incident). Re-add only
  // if a real containment query (@>, Prisma `path`/`has`) is introduced.
  @@index([deletedAt]) // For cleanup queries and filtering soft-deleted messages
  @@map("conversation_history")
}

/// Tombstone records for hard-deleted conversation history messages
/// Used by db-sync to prevent resurrection of deleted messages
/// The actual message data is deleted; this just records the deletion event
model ConversationHistoryTombstone {
  id            String   @id @db.Uuid // Same ID as the deleted message
  channelId     String   @map("channel_id") @db.VarChar(20)
  personalityId String   @map("personality_id") @db.Uuid
  personaId     String   @map("persona_id") @db.Uuid
  deletedAt     DateTime @default(now()) @map("deleted_at")

  @@index([channelId, personalityId, personaId])
  @@index([deletedAt]) // For periodic cleanup of old tombstones
  @@map("conversation_history_tombstones")
}

/// Generalized deletion ledger for db-sync: one row per hard-deleted row of a
/// synced table, written by the sync_tombstone_capture() AFTER DELETE trigger
/// (see migration 20260710230428). Sync consults it so a row deleted in one
/// environment is DELETE-propagated to the other instead of resurrected.
/// row_pk encodes composite keys with '|' (matching SyncUpsertBuilder's
/// getPrimaryKey). Deliberately NO relations — a tombstone must survive the
/// deletion of everything it references. Rows are pruned after the retention
/// window once both sides have synced past them.
model SyncTombstone {
  /// Snake_case table name as reported by TG_TABLE_NAME.
  tableName String   @map("table_name") @db.VarChar(64)
  /// The deleted row's SYNC_CONFIG primary key, '|'-joined when composite.
  rowPk     String   @map("row_pk") @db.VarChar(255)
  /// Latest deletion time — a delete→recreate→delete sequence keeps the
  /// newest (trigger upserts on conflict).
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@id([tableName, rowPk])
  @@index([deletedAt]) // retention pruning
  @@map("sync_tombstones")
}

model PendingMemory {
  id                    String               @id @db.Uuid
  conversationHistoryId String?              @unique @map("conversation_history_id") @db.Uuid
  personaId             String               @map("persona_id") @db.Uuid
  personalityId         String               @map("personality_id") @db.Uuid
  text                  String
  metadata              Json
  createdAt             DateTime             @default(now()) @map("created_at")
  attempts              Int                  @default(0)
  lastAttemptAt         DateTime?            @map("last_attempt_at")
  error                 String?
  conversationHistory   ConversationHistory? @relation(fields: [conversationHistoryId], references: [id], onDelete: Cascade)

  @@index([personaId])
  @@index([personalityId])
  @@index([createdAt])
  @@index([attempts, createdAt]) // For pending memory retry queries
  @@map("pending_memories")
}

/// Unified channel settings - replaces ActivatedChannel.
/// Stores both activation settings and extended context preferences per channel.
/// Note: channelId is unique (not channelId+personalityId) - one personality per channel.
model ChannelSettings {
  id        String  @id @db.Uuid
  channelId String  @unique @map("channel_id") @db.VarChar(20)
  guildId   String? @map("guild_id") @db.VarChar(20)

  // Activation settings (migrated from ActivatedChannel)
  activatedPersonalityId String? @map("activated_personality_id") @db.Uuid
  autoRespond            Boolean @default(true) @map("auto_respond")

  // Config cascade overrides (channel tier — between personality and user tiers)
  configOverrides Json? @map("config_overrides")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdByUser        User?        @relation(fields: [createdBy], references: [id])
  activatedPersonality Personality? @relation(fields: [activatedPersonalityId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@index([guildId])
  @@index([activatedPersonalityId])
  @@map("channel_settings")
}

model Memory {
  id                   String                 @id @db.Uuid
  personaId            String?                @map("persona_id") @db.Uuid
  personalityId        String                 @map("personality_id") @db.Uuid
  content              String
  /// Vector embedding for similarity search (BGE-small-en-v1.5: 384 dimensions)
  /// Index: idx_memories_embedding USING ivfflat (embedding vector_cosine_ops) WITH (lists = 50)
  /// Managed outside Prisma - see prisma/drift-ignore.json
  embedding            Unsupported("vector")?
  isSummarized         Boolean                @default(false) @map("is_summarized")
  originalMessageCount Int?                   @map("original_message_count")
  summarizedAt         DateTime?              @map("summarized_at")
  sessionId            String?                @map("session_id") @db.VarChar(255)
  canonScope           String?                @map("canon_scope") @db.VarChar(20)
  summaryType          String?                @map("summary_type") @db.VarChar(50)
  channelId            String?                @map("channel_id") @db.VarChar(20)
  guildId              String?                @map("guild_id") @db.VarChar(20)
  messageIds           String[]               @map("message_ids")
  senders              String[]
  createdAt            DateTime               @default(now()) @map("created_at")
  /// Track when memory content was last modified (for edit history)
  updatedAt            DateTime               @default(now()) @updatedAt @map("updated_at")
  legacyShapesUserId   String?                @map("legacy_shapes_user_id") @db.Uuid
  sourceSystem         String                 @default("tzurot-v3") @map("source_system") @db.VarChar(50)
  /// Memory type: 'memory' for conversation summaries, 'knowledge' for imported knowledge base entries
  type                 String                 @default("memory") @map("type") @db.VarChar(20)
  /// Protected "core memories" that survive batch delete and purge operations
  isLocked             Boolean                @default(false) @map("is_locked")
  /// Memory visibility: normal (live), deleted (soft-deleted — excluded from RAG
  /// retrieval and user-facing lists; written by memory delete paths and
  /// message-deletion propagation), hidden/archived (reserved for future use)
  visibility           String                 @default("normal") @map("visibility") @db.VarChar(20)
  /// Memory pool (social scoping matrix): 'private' = persona×personality (today's
  /// only behavior, the default); 'community' = server-communal pool (Phase 3 —
  /// rows only ever written after per-user opt-in consent); 'canon' = canon-group
  /// world knowledge (Phase 3+). Column lands in Phase 0 so later extraction
  /// writes correctly-scoped rows without a re-scope migration.
  pool                 String                 @default("private") @map("pool") @db.VarChar(20)
  /// Canon-group id for pool='canon' rows; null for private/community pools
  /// (state-machine-by-status: tied to pool, meaningless otherwise).
  canonGroupId         String?                @map("canon_group_id") @db.Uuid
  /// Fiction/reality split (R7): true = in-character canon (scene events), false =
  /// true-user-facts. Defaults false; Phase 2 extraction sets it from scope
  /// defaults + explicit user markers (owner decision: scope+markers canonical).
  isFiction            Boolean                @default(false) @map("is_fiction")
  // Chunk linking fields for oversized memories split into multiple chunks
  chunkGroupId         String?                @map("chunk_group_id") @db.Uuid
  chunkIndex           Int?                   @map("chunk_index")
  totalChunks          Int?                   @map("total_chunks")
  persona              Persona?               @relation(fields: [personaId], references: [id], onDelete: Cascade)
  personality          Personality            @relation(fields: [personalityId], references: [id], onDelete: Cascade)

  @@index([personaId])
  @@index([personalityId])
  @@index([createdAt(sort: Desc)])
  @@index([channelId])
  @@index([guildId])
  @@index([sessionId])
  @@index([isSummarized])
  @@index([legacyShapesUserId])
  @@index([sourceSystem])
  @@index([messageIds], type: Gin)
  @@index([pool])
  // NOTE: isLocked uses a PARTIAL index (WHERE is_locked = true) managed via raw migration
  // for efficient locked memory queries. Declared here for drift detection.
  @@index([isLocked])
  @@index([visibility])
  // NOTE: chunkGroupId uses a PARTIAL index (WHERE chunk_group_id IS NOT NULL)
  // managed via raw migration. Prisma schema declares it for drift detection but
  // the actual index excludes NULL values to save space on non-chunked memories.
  @@index([chunkGroupId])
  // NOTE: The IVFFlat vector index (idx_memories_embedding) is managed outside Prisma
  // because Unsupported types don't support vector-specific operators (VectorCosineOps)
  // See: docs/database/PRISMA_DRIFT_ISSUES.md
  @@map("memories")
}

model MemoryFact {
  id            String  @id @db.Uuid
  personalityId String  @map("personality_id") @db.Uuid
  /// Null for world/canon facts not tied to a specific persona relationship;
  /// populated for persona-scoped facts (the common extraction case).
  personaId     String? @map("persona_id") @db.Uuid

  // Scoping mirror of Memory (varchar + zod validation, per house convention)
  /// Memory pool: 'private' (default) | 'community' | 'canon' — same vocabulary
  /// as memories.pool; extraction writes correctly-scoped rows from day one.
  pool         String  @default("private") @map("pool") @db.VarChar(20)
  /// Canon-group id for pool='canon' rows; null for private/community pools
  /// (state-machine-by-status: tied to pool, meaningless otherwise).
  canonGroupId String? @map("canon_group_id") @db.Uuid
  /// Fiction/reality split (R7): true = in-character canon, false = true-user-facts.
  isFiction    Boolean @default(false) @map("is_fiction")
  /// 'normal' (live) | 'deleted' (soft-deleted, excluded from retrieval).
  visibility   String  @default("normal") @map("visibility") @db.VarChar(20)
  /// Hard freeze, same semantics as Memory.isLocked (one word, one meaning):
  /// rejects /memory correct and /memory forget (unlock first) AND is never
  /// auto-superseded by extraction. Corrections need no lock — the 'corrected'
  /// tier itself shields them from automatic supersession.
  isLocked     Boolean @default(false) @map("is_locked")

  // Fact core
  /// Atomic normalized statement ("Alice's cat is named Miso").
  statement  String
  /// Vector embedding for similarity search (BGE-small-en-v1.5: 384 dimensions).
  /// Index: idx_memory_facts_embedding USING ivfflat (embedding vector_cosine_ops) WITH (lists = 50)
  /// Managed outside Prisma - see prisma/drift-ignore.json
  embedding  Unsupported("vector")?
  /// Flat entity tags ("user:alice", "topic:cooking") — the lean stand-in for a
  /// dedicated entities table (deferred until an eval demonstrates multi-hop need).
  entityTags String[]               @default([]) @map("entity_tags")
  /// Extraction-model-assigned importance, 0..1.
  salience   Float                  @default(0.5)
  /// 'observed' (extracted) | 'inferred' (consolidation, future) | 'corrected' (/memory correct).
  tier       String                 @default("observed") @map("tier") @db.VarChar(20)

  // Supersession chain (forward-only log; never un-supersede)
  validFrom      DateTime  @default(now()) @map("valid_from")
  /// Null while the fact is current; populated when a newer fact supersedes it
  /// or /memory forget terminates it (state machine — never reverts).
  supersededAt   DateTime? @map("superseded_at")
  /// The superseding fact's id; null for current facts AND for terminal
  /// /memory forget removals (forgotten=true marks those).
  supersededById String?   @map("superseded_by_id") @db.Uuid
  /// Terminal user-initiated removal (distinct from supersession-by-newer-fact);
  /// forgotten facts never re-enter retrieval or supersession context.
  forgotten      Boolean   @default(false)

  // Provenance
  /// Source episode Memory.ids this fact was extracted from (correction-authored
  /// facts carry the corrected fact's sources forward).
  sourceMemoryIds String[] @default([]) @map("source_memory_ids")
  /// BullMQ extraction job id for traceability; null for user-authored
  /// (corrected-tier) facts, which have no extraction job.
  extractionJobId String?  @map("extraction_job_id") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  personality  Personality  @relation(fields: [personalityId], references: [id], onDelete: Cascade)
  persona      Persona?     @relation(fields: [personaId], references: [id], onDelete: Cascade)
  supersededBy MemoryFact?  @relation("FactSupersession", fields: [supersededById], references: [id])
  supersedes   MemoryFact[] @relation("FactSupersession")

  // Active-facts query path (slice 2 supersession context + slice 4 retrieval filter)
  @@index([personalityId, personaId, supersededAt])
  // FK-cascade support: persona deletion cascades onto memory_facts; without a
  // personaId-leading index that delete seq-scans the table (mirrors Memory).
  @@index([personaId])
  // Tag-based lookup (slice 2 similarity-fallback entity-overlap guard)
  @@index([entityTags], type: Gin)
  @@index([supersededById])
  // NOTE: The IVFFlat vector index (idx_memory_facts_embedding) is managed outside
  // Prisma (Unsupported types can't declare VectorCosineOps) — slice-4 fact
  // similarity retrieval. See docs/database/PRISMA_DRIFT_ISSUES.md + drift-ignore.json.
  @@map("memory_facts")
}

model ShapesPersonaMapping {
  id                 String   @id @db.Uuid
  shapesUserId       String   @unique @map("shapes_user_id") @db.Uuid
  personaId          String   @map("persona_id") @db.Uuid
  mappedAt           DateTime @default(now()) @map("mapped_at")
  mappedBy           String?  @map("mapped_by") @db.Uuid
  verificationStatus String   @default("unverified") @map("verification_status") @db.VarChar(50)
  persona            Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId])
  @@map("shapes_persona_mappings")
}

model JobResult {
  jobId       String    @id @map("job_id") @db.VarChar(255)
  requestId   String    @map("request_id") @db.VarChar(255)
  result      Json
  status      String    @db.VarChar(50) // PENDING_DELIVERY, DELIVERED
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  deliveredAt DateTime? @map("delivered_at")

  @@index([status, completedAt])
  @@map("job_results")
}

/// "Flight recorder" for LLM requests - captures full pipeline data for debugging.
/// Ephemeral: auto-deleted after 24 hours via BullMQ cleanup job.
/// NOTE: Uses @default(uuid()) instead of deterministic UUIDs since this is
/// debug data that doesn't sync between environments.
model LlmDiagnosticLog {
  /// Auto-generated UUID (ephemeral data, no sync needed)
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  /// Link to the request for lookup (e.g., from /admin debug command)
  requestId String @unique @map("request_id") @db.VarChar(255)

  /// Discord message ID that triggered this request (for diagnostic lookup by message)
  triggerMessageId String? @map("trigger_message_id") @db.VarChar(20)

  /// Discord message IDs for AI response chunks (for lookup by response message)
  /// Populated after response is sent to Discord via PATCH endpoint
  responseMessageIds String[] @default([]) @map("response_message_ids")

  /// Top-level indexed fields for filtering/queries
  personalityId String? @map("personality_id") @db.Uuid
  userId        String? @map("user_id") @db.VarChar(20)
  guildId       String? @map("guild_id") @db.VarChar(20)
  channelId     String? @map("channel_id") @db.VarChar(20)
  model         String  @db.VarChar(255)
  provider      String  @db.VarChar(50)
  durationMs    Int     @map("duration_ms")

  /// The full diagnostic payload - see DiagnosticPayload type in ai-worker
  /// Contains: meta, inputContext, assembledPrompt, llmConfig, llmResponse, postProcessing
  data Json

  @@index([createdAt])
  @@index([triggerMessageId])
  @@index([responseMessageIds], type: Gin)
  @@index([personalityId])
  @@index([userId])
  @@index([guildId])
  @@index([channelId])
  @@map("llm_diagnostic_logs")
}

/// Denylist: block specific Discord users or guilds from using the bot.
/// Supports granular scoping: bot-wide, channel-specific, or personality-specific.
/// All denials are silent - the bot simply doesn't respond.
model DenylistedEntity {
  /// Auto-generated UUID (operational data, no sync needed)
  id        String   @id @default(uuid()) @db.Uuid
  /// Entity type: 'USER' or 'GUILD'
  type      String   @db.VarChar(10)
  /// Discord snowflake ID of the user or guild
  discordId String   @map("discord_id") @db.VarChar(20)
  /// Scope of denial: 'BOT' (all), 'CHANNEL' (specific channel), 'PERSONALITY' (specific character)
  scope     String   @default("BOT") @db.VarChar(15)
  /// Target ID for scoped denials. '*' for BOT scope, channel/personality ID otherwise.
  scopeId   String   @default("*") @map("scope_id") @db.VarChar(40)
  /// Denial mode: 'BLOCK' (full deny, default) or 'MUTE' (don't respond but keep in context)
  mode      String   @default("BLOCK") @db.VarChar(10)
  /// Optional reason for the denial
  reason    String?  @db.Text
  /// Discord ID of the admin who added this entry
  addedBy   String   @map("added_by") @db.VarChar(20)
  /// When this entry was created
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([type, discordId, scope, scopeId])
  @@index([type, discordId])
  @@index([type, addedAt])
  @@map("denylisted_entities")
}

/// Encrypted credentials for external service authentication (e.g., shapes.inc session cookies).
/// Uses AES-256-GCM encryption with same pattern as UserApiKey (iv, content, tag).
model UserCredential {
  id             String    @id @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  /// External service identifier (e.g., 'shapes_inc')
  service        String    @db.VarChar(50)
  /// Type of credential (e.g., 'session_cookie')
  credentialType String    @map("credential_type") @db.VarChar(50)
  iv             String    @db.VarChar(32)
  content        String    @db.Text
  tag            String    @db.VarChar(32)
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service, credentialType])
  @@index([userId])
  @@map("user_credentials")
}

/// Tracks import job history and audit trail for character imports from external services.
model ImportJob {
  id               String       @id @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  personalityId    String?      @map("personality_id") @db.Uuid
  /// Original slug/username on the source service
  sourceSlug       String       @map("source_slug") @db.VarChar(255)
  /// Source service identifier (e.g., 'shapes_inc')
  sourceService    String       @map("source_service") @db.VarChar(50)
  /// Job status: pending, in_progress, completed, failed
  status           String       @default("pending") @db.VarChar(50)
  /// Whether this is a full import (owner) or memory-only (non-owner)
  importType       String       @default("full") @map("import_type") @db.VarChar(20)
  memoriesImported Int?         @map("memories_imported")
  memoriesFailed   Int?         @map("memories_failed")
  createdAt        DateTime     @default(now()) @map("created_at")
  startedAt        DateTime?    @map("started_at")
  completedAt      DateTime?    @map("completed_at")
  errorMessage     String?      @map("error_message")
  /// Additional metadata (source config snapshot, stats, etc.)
  importMetadata   Json?        @map("import_metadata")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personality      Personality? @relation(fields: [personalityId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceSlug, sourceService])
  @@index([userId])
  @@index([status])
  @@map("import_jobs")
}

/// Tracks export job history for async data exports from external services.
/// File content is stored as PostgreSQL TEXT (TOAST handles large values efficiently).
/// Records auto-expire after 24 hours via scheduled cleanup job.
model ExportJob {
  id             String    @id @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  /// Original slug/username on the source service
  sourceSlug     String    @map("source_slug") @db.VarChar(255)
  /// Source service identifier (e.g., 'shapes_inc')
  sourceService  String    @map("source_service") @db.VarChar(50)
  /// Job status: pending, in_progress, completed, failed
  status         String    @default("pending") @db.VarChar(50)
  /// Export format: json, markdown, or zip
  format         String    @default("json") @db.VarChar(20)
  /// Full export content stored as text (TOAST-compressed, supports 35MB+)
  fileContent    String?   @map("file_content")
  /// Binary export payload (ZIP archives). Deferred-set like fileContent:
  /// null until a binary-format job completes; a completed job populates
  /// exactly one of fileContent (text formats) or fileData (binary formats).
  fileData       Bytes?    @map("file_data")
  /// Generated filename for download
  fileName       String?   @map("file_name") @db.VarChar(255)
  /// Size of the stored payload (fileContent or fileData) in bytes
  fileSizeBytes  Int?      @map("file_size_bytes")
  /// Unguessable random token carried in the PUBLIC download URL (the job `id`
  /// is deterministic and must never be the download handle). Deferred-set:
  /// null only on legacy rows predating this column; every new/reset job mints
  /// one. Unique so the unauthenticated download route can look up by it.
  downloadToken  String?   @unique @map("download_token") @db.VarChar(64)
  createdAt      DateTime  @default(now()) @map("created_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  /// When this export job expires and should be cleaned up
  expiresAt      DateTime  @map("expires_at")
  errorMessage   String?   @map("error_message")
  /// Additional metadata (stats, source config snapshot, etc.)
  exportMetadata Json?     @map("export_metadata")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Deterministic UUID (from userId+slug+service+format) already prevents duplicates,
  // but the unique constraint makes the intent explicit at the DB level.
  @@unique([userId, sourceSlug, sourceService, format])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("export_jobs")
}

/// Minimum release weight a user wants DM'd. Weights are CHANGELOG-derived
/// (Breaking Changes→major, Features→minor, fixes-only→patch), NOT semver-delta —
/// beta bumps classify by their content.
/// Declaration order (major < minor < patch) is LOAD-BEARING: Postgres enum
/// comparison follows it, so the eligibility query can use release.level <=
/// user.notify_level. Do not reorder.
enum NotifyLevel {
  major
  minor
  patch

  @@map("notify_level")
}

/// Release-DM delivery outcome per (release, user).
enum DeliveryStatus {
  pending
  sent
  failed_transient
  failed_permanent

  @@map("delivery_status")
}

/// Feedback triage state (owner-driven).
enum FeedbackStatus {
  new
  read
  archived

  @@map("feedback_status")
}

/// One row per announced release — the delivery pipeline's idempotency backbone
/// (GitHub retries webhooks; the unique version means at most one blast per release).
model ReleaseAnnouncement {
  id              String               @id @db.Uuid
  version         String               @unique @db.VarChar(50)
  /// Changelog-derived weight of this release (see NotifyLevel).
  level           NotifyLevel
  githubReleaseId String               @map("github_release_id") @db.VarChar(30)
  /// Raw release-notes markdown captured at trigger time — retries and the DM
  /// formatter read this instead of refetching from GitHub.
  body            String
  createdAt       DateTime             @default(now()) @map("created_at")
  /// State machine: null until the DM blast finishes; set atomically with the
  /// final delivery-log write.
  completedAt     DateTime?            @map("completed_at")
  deliveries      ReleaseDeliveryLog[]

  @@map("release_announcements")
}

/// Per-(release, user) delivery outcome — retry-exactly-the-failures, failure
/// classification, and the post-blast ops report all read from here.
model ReleaseDeliveryLog {
  id               String              @id @db.Uuid
  releaseId        String              @map("release_id") @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  status           DeliveryStatus      @default(pending)
  /// State-machine-by-status: null unless status is failed_*; carries the
  /// Discord error class (e.g. 50007 = cannot DM this user).
  errorCode        String?             @map("error_code") @db.VarChar(50)
  /// Deferred-set: null on row creation; stamped by the gateway's
  /// delivery-status endpoint when the DM worker (bot-client, Prisma-free)
  /// reports the batch's outcomes.
  attemptedAt      DateTime?           @map("attempted_at")
  /// Deferred-set: null until the DM send succeeds; then carries the sent
  /// Discord message's snowflake so cleanup (auto delete-previous on the next
  /// blast, /notifications cleanup) can delete the DM without history scans.
  sentMessageId    String?             @map("sent_message_id") @db.VarChar(30)
  /// State machine: null while the sent DM may still exist in the user's DM
  /// channel; stamped when a cleanup path confirms deletion (a 10008
  /// already-gone counts — the goal state is "message absent", however reached).
  messageDeletedAt DateTime?           @map("message_deleted_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  release          ReleaseAnnouncement @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // userId follows the schema-wide "every userId FK is indexed" convention
  // (ON DELETE CASCADE is an implicit query on parent-row deletes). Query-shaped
  // secondary indexes (retry sweep, ops report) still land with their queries
  // per 03-database "indexes ship with their query".
  @@unique([releaseId, userId])
  @@index([userId])
  @@map("release_delivery_log")
}

/// User-submitted feedback (abuse-gated at the gateway). The owner triages via
/// status; a silent post to the private owner channel mirrors each row.
model UserFeedback {
  id          String         @id @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  content     String         @db.VarChar(2000)
  /// sha-256 hex of normalized content — near-dup rejection compares against
  /// the user's recent rows.
  contentHash String         @map("content_hash") @db.VarChar(64)
  status      FeedbackStatus @default(new)
  createdAt   DateTime       @default(now()) @map("created_at")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Schema-wide convention: every userId FK is indexed (cascade deletes are
  // implicit queries).
  @@index([userId])
  // Near-dup dedupe: the intake gate looks up (userId, contentHash) within
  // the dedupe window before accepting a submission.
  @@index([userId, contentHash])
  @@map("user_feedback")
}

/// Per-secret rotation ledger — environment-LOCAL operational state (each
/// env's DB records its own rotations; excluded from db-sync). Written by the
/// `pnpm ops secrets:*` commands; read by the internal rotation-status route
/// that feeds the weekly owner-channel overdue nag.
model SecretRotation {
  /// Ledger key, e.g. 'byok-encryption-key', 'internal-service-secret'.
  name         String   @id @db.VarChar(50)
  rotatedAt    DateTime @map("rotated_at")
  intervalDays Int      @map("interval_days")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("secret_rotations")
}
