{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.js", "*.config.ts", "eslint.config.js"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.ts", "vitest.config.ts"],
      "outputs": ["coverage/**", "junit.xml"],
      "cache": true,
      "env": ["CI", "NODE_ENV"]
    },
    "@tzurot/common-types#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "*.config.ts",
        "vitest.config.ts",
        "../../services/*/src/**",
        "../../packages/*/src/**"
      ],
      "outputs": ["coverage/**", "junit.xml"],
      "cache": true,
      "env": ["CI", "NODE_ENV"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.ts", "vitest.config.ts"],
      "outputs": ["coverage/**"],
      "cache": true,
      "env": ["CI", "NODE_ENV"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": [],
      "cache": true
    },
    "@tzurot/scripts#typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["*.ts", "migrations/**/*.ts", "tsconfig.json"],
      "outputs": [],
      "cache": true
    },
    "@tzurot/bot-client#typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "scripts/**", "tsconfig.json", "tsconfig.typecheck.json"],
      "outputs": [],
      "cache": true
    },
    "typecheck:spec": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "tsconfig.spec.json"],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
