{
  "name": "@tzurot/embeddings",
  "version": "3.0.0-beta.163",
  "private": true,
  "type": "module",
  "description": "Local embedding service using bge-small-en-v1.5 for semantic similarity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "find src -name '*.js' -type f -delete && find src -name '*.js.map' -type f -delete",
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "pretest": "npm run clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc --noEmit --project tsconfig.spec.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tzurot/common-types": "workspace:*",
    "onnxruntime-node": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
