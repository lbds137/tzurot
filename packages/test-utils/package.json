{
  "name": "@tzurot/test-utils",
  "version": "3.0.0-beta.126",
  "private": true,
  "type": "module",
  "description": "Shared test utilities for Tzurot services",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc --noEmit --project tsconfig.spec.json"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "ioredis": "^5.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
