{
  "name": "tzurot",
  "version": "3.0.0-beta.159",
  "private": true,
  "description": "Next-generation Discord AI bot with customizable personalities",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate || true",
    "prepare": "husky || true",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start:bot": "pnpm --filter @tzurot/bot-client start",
    "start:gateway": "pnpm --filter @tzurot/api-gateway start",
    "start:worker": "pnpm --filter @tzurot/ai-worker start",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:component",
    "test:low-mem": "LOW_RESOURCE_MODE=1 NODE_OPTIONS=--max-old-space-size=2048 pnpm --workspace-concurrency=1 --filter './services/*' --filter './packages/*' test",
    "test:failures": "turbo run test --output-logs=errors-only -- --reporter=verbose",
    "test:summary": "pnpm ops dev:test-summary",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "lint:errors": "turbo run lint --output-logs=errors-only -- --quiet --format=pretty",
    "typecheck": "turbo run typecheck",
    "typecheck:spec": "turbo run typecheck:spec",
    "cpd": "jscpd ./services ./packages --config .jscpd.json",
    "cpd:report": "jscpd ./services ./packages --config .jscpd.json --reporters html",
    "depcruise": "depcruise services/ packages/ --config .dependency-cruiser.cjs",
    "depcruise:graph": "depcruise services/ packages/ --config .dependency-cruiser.cjs --output-type dot | dot -T svg > reports/dependency-graph.svg",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:dead": "tsx packages/tooling/src/cli.ts dev:dead-files",
    "commands:audit": "tsx packages/tooling/src/cli.ts commands:audit",
    "backlog:lint": "tsx packages/tooling/src/cli.ts backlog",
    "ops:health": "tsx packages/tooling/src/cli.ts health",
    "test:tiers": "tsx packages/tooling/src/cli.ts test:tiers",
    "quality": "pnpm lint && pnpm ops codegen:routes --check && pnpm ops codegen:command-types --check && pnpm ops topology:check && pnpm knip && pnpm knip:dead && pnpm cpd && pnpm ops cpd:check && pnpm ops test:audit && pnpm depcruise && pnpm typecheck && pnpm typecheck:spec && pnpm backlog:lint && pnpm ops guard:test-taxonomy && pnpm ops guard:workflow-sync && pnpm ops guard:proposal-links && pnpm ops guard:audit-tool-docs && pnpm ops guard:claude-content-refs && pnpm ops guard:duplicate-exports && pnpm ops guard:no-export-star && pnpm ops guard:prompt-tags && pnpm ops guard:dockerfile-dist && pnpm ops commands:audit && pnpm ops xray --suppressions --check && pnpm ops lines:check && pnpm ops ux:literals && pnpm ops guard:gate-parity",
    "focus:lint": "pnpm ops dev:lint",
    "focus:test": "pnpm ops dev:test",
    "focus:build": "pnpm ops dev:focus build",
    "focus:typecheck": "pnpm ops dev:typecheck",
    "format": "prettier --write .",
    "audit:contracts": "pnpm ops test:audit-contracts",
    "audit:services": "pnpm ops test:audit-services",
    "generate:pglite": "pnpm ops test:generate-schema",
    "generate:command-types": "pnpm ops codegen:command-types",
    "update-deps": "pnpm ops dev:update-deps",
    "check:migrations": "pnpm ops db:check-safety",
    "bump-version": "pnpm ops release:bump",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "ops": "tsx packages/tooling/src/cli.ts",
    "with-env": "pnpm ops run --env",
    "eval:memory": "vitest run --config vitest.eval.config.ts services/ai-worker/src/services/eval/memoryRetrieval.eval.test.ts",
    "eval:extraction": "vitest run --config vitest.eval.config.ts services/ai-worker/src/services/eval/memoryExtraction.eval.test.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.21",
    "dependency-cruiser": "^18.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-formatter-pretty": "^7.1.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.5",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "pglite-prisma-adapter": "^0.7.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "secretlint": "^13.0.2",
    "tsx": "^4.23.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "publicHoistPattern": [
      "*debug*",
      "*eslint*"
    ],
    "overrides": {
      "undici": "^6.27.0",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "ioredis": "^5.11.1",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "hono@<4.12.25": ">=4.12.25",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "fast-uri@<3.1.2": ">=3.1.2",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "ajv@>=6.0.0 <6.14.0": ">=6.14.0 <7.0.0",
      "tar@<=7.5.10": ">=7.5.11",
      "langsmith@<0.5.19": ">=0.5.19",
      "protobufjs@<7.6.3": ">=7.6.3 <8.0.0",
      "protobufjs@>=8.0.0 <8.0.1": ">=8.0.1 <9.0.0",
      "@protobufjs/utf8@<1.1.1": ">=1.1.1 <2.0.0",
      "uuid@<14.0.0": ">=14.0.0",
      "qs@>=6.11.1 <6.15.2": ">=6.15.2 <7.0.0",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "read-yaml-file@<2.0.0": ">=2.0.0 <3.0.0"
    }
  }
}
