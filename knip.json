{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreWorkspaces": ["scripts", "tests"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "vitest": false,
      "ignoreDependencies": ["@typescript-eslint/eslint-plugin", "@typescript-eslint/parser"]
    },
    "services/bot-client": {
      "entry": ["src/**/*.test.ts", "src/commands/*/index.ts"]
    },
    "services/api-gateway": {
      "entry": ["src/**/*.test.ts"],
      "ignoreDependencies": ["openai", "pino"]
    },
    "services/ai-worker": {
      "entry": ["src/**/*.test.ts"],
      "ignoreDependencies": ["langchain", "onnxruntime-node"]
    },
    "packages/common-types": {
      "entry": ["src/**/*.test.ts", "src/schemas/api/**/*.ts", "src/generated/**/*.ts"],
      "ignoreDependencies": ["openai", "pg", "@prisma/client", "prisma"],
      "ignoreMembers": ["ECONNRESET", "ETIMEDOUT", "ENOTFOUND", "ECONNREFUSED"]
    },
    "packages/clients": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/config-resolver": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/identity": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/conversation-history": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/cache-invalidation": {
      "entry": ["src/**/*.test.ts"]
    },
    "packages/tooling": {
      "entry": ["src/**/*.test.ts"],
      "ignoreDependencies": ["eslint"]
    },
    "packages/embeddings": {
      "entry": ["src/**/*.test.ts", "src/embeddingWorker.ts"],
      "includeEntryExports": true,
      "ignoreDependencies": ["onnxruntime-node"]
    },
    "packages/test-utils": {
      "entry": ["src/**/*.test.ts"],
      "includeEntryExports": true
    },
    "packages/test-factories": {
      "entry": ["src/**/*.test.ts"],
      "includeEntryExports": true
    }
  },
  "ignore": [
    "tzurot-legacy/**",
    "**/vitest.config.ts",
    "**/test/setup.ts",
    "vitest.workspace.ts",
    "**/__mocks__/**",
    "audit.config.ts",
    "**/test-fixtures/audit-canaries/**"
  ],
  "ignoreBinaries": ["dot", "ffmpeg", "ffprobe", "gh", "ops", "railway", "ruff"],
  "ignoreDependencies": [
    "@secretlint/secretlint-rule-preset-recommend",
    "eslint-formatter-pretty",
    "pino-pretty"
  ]
}
