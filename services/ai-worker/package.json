{
  "name": "@tzurot/ai-worker",
  "version": "3.0.0-beta.122",
  "private": true,
  "type": "module",
  "description": "AI processing worker service for Tzurot bot",
  "main": "dist/index.js",
  "scripts": {
    "clean": "find src -name '*.js' -type f -delete && find src -name '*.js.map' -type f -delete",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "npm run clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:spec": "tsc --noEmit --project tsconfig.spec.json"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/openai": "^1.4.5",
    "@tzurot/common-types": "workspace:*",
    "@tzurot/embeddings": "workspace:*",
    "bullmq": "^5.76.7",
    "fast-xml-parser": "^5.7.3",
    "ioredis": "^5.10.0",
    "langchain": "^1.4.0",
    "onnxruntime-node": "^1.26.0",
    "pino": "^10.3.1",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@tzurot/test-utils": "workspace:*"
  }
}
