{
  "name": "@tzurot/website",
  "version": "3.0.0-beta.166",
  "private": true,
  "type": "module",
  "description": "Public website for Tzurot (tzurot.org) — landing page + legal documents",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "astro sync && eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.1",
    "@fontsource-variable/inter": "^5.2.5",
    "astro": "^6.4.6",
    "marked": "^18.0.6",
    "marked-smartypants": "^1.1.12",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.3"
  }
}
