---
import { getEntry } from 'astro:content';
import Prose from '../layouts/Prose.astro';
import { BRAND } from '../brand';

const entry = await getEntry('legal', 'terms_of_service');
if (!entry?.body) {
  throw new Error('docs/legal/TERMS_OF_SERVICE.md is missing from the content collection');
}
---

<Prose
  title={`Terms of Service — ${BRAND.name}`}
  description={`The terms that govern use of the ${BRAND.name} Discord bot.`}
  path="/terms"
  body={entry.body}
/>
