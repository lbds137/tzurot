---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { BRAND } from '../brand';
---

<Base title={`Not found — ${BRAND.name}`} description="Page not found.">
  <section class="container notfound">
    <Image src={BRAND.logo} alt="" width={160} height={160} class="notfound-mark" />
    <h1>404</h1>
    <p>This page doesn't exist — the cube has no such face.</p>
    <a class="button button--primary" href="/">Back home</a>
  </section>
</Base>

<style>
  .notfound {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: 5rem;
    gap: 0.75rem;
  }

  .notfound-mark {
    width: 120px;
    height: 120px;
    opacity: 0.85;
  }

  .notfound h1 {
    margin: 0;
    font-size: 3.5rem;
  }

  .notfound p {
    color: var(--text-muted);
    margin: 0 0 1rem;
  }
</style>
