---
import { getEntry } from 'astro:content';
import Prose from '../layouts/Prose.astro';
import { BRAND } from '../brand';

const entry = await getEntry('legal', 'privacy_policy');
if (!entry?.body) {
  throw new Error('docs/legal/PRIVACY_POLICY.md is missing from the content collection');
}
---

<Prose
  title={`Privacy Policy — ${BRAND.name}`}
  description={`What the ${BRAND.name} Discord bot collects, why, where it goes, and the controls you have over it.`}
  path="/privacy"
  body={entry.body}
/>
