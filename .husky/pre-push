#!/bin/sh

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running pre-push checks..."

# 1. Validate branch name (skip for main/develop/scratch)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "develop" ] && [ "$BRANCH" != "main" ]; then
    # Allow scratch/ prefix for WIP branches (skip all checks)
    if echo "$BRANCH" | grep -q "^scratch/"; then
        echo "${YELLOW}Scratch branch detected - skipping all checks${NC}"
        exit 0
    fi

    # Validate branch naming convention (dependabot/* allowed for automated dep PRs
    # that a maintainer may need to amend locally — e.g., when a knip/eslint upgrade
    # surfaces new findings the contributor has to fix before merge).
    if ! echo "$BRANCH" | grep -qE "^(feat|fix|chore|refactor|docs|test|ci|build|perf|style|revert|debug|dependabot)/"; then
        echo "${RED}Branch name must follow pattern: type/description${NC}"
        echo "   Valid types: feat, fix, chore, refactor, docs, test, ci, build, perf, style, revert, debug, dependabot"
        echo "   Example: feat/add-user-auth"
        echo "   Use scratch/ prefix for WIP branches that skip checks"
        exit 1
    fi
fi

# 2. Determine what files are being pushed
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")

if [ -n "$UPSTREAM" ]; then
    CHANGED_FILES=$(git diff --name-only "$UPSTREAM" HEAD 2>/dev/null || true)
else
    BASE_BRANCH=$(git rev-parse --verify origin/develop 2>/dev/null || git rev-parse --verify origin/main 2>/dev/null || echo "")
    if [ -n "$BASE_BRANCH" ]; then
        MERGE_BASE=$(git merge-base HEAD "$BASE_BRANCH" 2>/dev/null || echo "$BASE_BRANCH")
        CHANGED_FILES=$(git diff --name-only "$MERGE_BASE" HEAD 2>/dev/null || true)
    else
        CHANGED_FILES=""
    fi
fi

# 2b. Surface deferred backlog rows referencing files in this push (branch-level
# window — the pre-commit --staged pass only sees one commit's files, so a
# trigger touched earlier on the branch would otherwise slip by unseen).
# Informational only; never blocks the push.
if [ -n "$CHANGED_FILES" ]; then
    # shellcheck disable=SC2086 -- word-splitting the file list is intended
    pnpm ops dev:deferred-refs $CHANGED_FILES || true
fi

# 3. Check if only docs/config changed
# Include package.json and pnpm-lock.yaml as they can affect builds (dependencies, scripts)
CODE_FILES=$(echo "$CHANGED_FILES" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|d\.ts)$|package\.json$|pnpm-lock\.yaml$' || true)
PYTHON_FILES=$(echo "$CHANGED_FILES" | grep -E '\.py$' || true)

if [ -z "$CHANGED_FILES" ]; then
    echo "${YELLOW}No files detected in push - skipping checks${NC}"
    exit 0
elif [ -z "$CODE_FILES" ] && [ -z "$PYTHON_FILES" ]; then
    # Docs-only pushes skip builds and tests, but they are exactly how the
    # always-loaded context surfaces (.claude/rules/*.md, CURRENT.md) and the
    # backlog layout bloat — so the two cheap doc budgets (<2s) still run.
    echo "Docs-only push detected - running line-budget and backlog checks..."
    if ! pnpm ops lines:check; then
        echo "${RED}Always-loaded context line budget exceeded!${NC}"
        echo "Trim the surface, or make growth explicit: pnpm ops lines:update-baseline"
        exit 1
    fi
    if ! pnpm backlog:lint; then
        echo "${RED}Backlog layout check failed!${NC}"
        echo "Fix the HOT/COLD caps or dangling links before pushing"
        exit 1
    fi
    # Workflow-only pushes (.github/workflows/*.yml matches neither CODE_FILES
    # nor PYTHON_FILES) land in this branch too — and a claude workflow change
    # sneaking toward develop is exactly what guard:workflow-sync catches.
    # Cheap (a couple of git calls); self-skips on main-cut branches.
    if ! pnpm ops guard:workflow-sync; then
        echo "${RED}Workflow-sync guard failed!${NC}"
        echo "Route .github/workflows/ changes through a main-cut PR (see tzurot-git-workflow skill)"
        exit 1
    fi
    echo "${GREEN}Only documentation/config files changed - skipping build and tests${NC}"
    exit 0
fi

# 4. Detect resource-constrained environment
# Use LOW_RESOURCE_MODE=1 env var to enable throttling (e.g., for Steam Deck)
# Can be set in .env or shell profile
TURBO_ARGS="--output-logs=errors-only"

# Source LOW_RESOURCE_MODE from .env if not already set
if [ -z "$LOW_RESOURCE_MODE" ] && [ -f ".env" ]; then
    LOW_RESOURCE_MODE=$(grep -E '^LOW_RESOURCE_MODE=' .env | cut -d '=' -f2-)
fi

if [ -n "$LOW_RESOURCE_MODE" ]; then
    echo "${YELLOW}Low-resource mode enabled - throttling builds${NC}"
    # Limit to 1 concurrent task to prevent memory explosion
    TURBO_ARGS="$TURBO_ARGS --concurrency=1"
    # Cap Node.js memory to 2GB per process
    export NODE_OPTIONS="--max-old-space-size=2048"
    # Export the flag itself so the vitest subprocess (turbo → pnpm → vitest)
    # sees it and drops maxWorkers to 1 (see vitest.config.ts). Sourced from
    # .env above as a local shell var; without this export child processes
    # never see it and the intra-package thread count stays at 3.
    export LOW_RESOURCE_MODE
fi

# 5. Determine filter scope for Turbo
# Use origin/develop as base (or origin/main as fallback)
if git rev-parse --verify origin/develop >/dev/null 2>&1; then
    FILTER_BASE="origin/develop"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
    FILTER_BASE="origin/main"
else
    FILTER_BASE=""
fi

if [ -n "$FILTER_BASE" ]; then
    # Filter to only packages changed since base branch (plus their dependents)
    TURBO_FILTER="--filter=...[$FILTER_BASE]"
    echo "Code changes detected. Running Turbo on affected packages..."
else
    # No base branch found, run on all packages
    TURBO_FILTER=""
    echo "Code changes detected. Running Turbo on all packages..."
fi

# 6. Run Turbo for cached builds and tests
# Ensure CI mode (no watch mode, no prompts)
export CI=true

# shellcheck disable=SC2086 - Intentional word splitting for Turbo args
# TURBO_FILTER and TURBO_ARGS are space-separated flags, never contain spaces in values
if ! pnpm turbo run build lint test $TURBO_FILTER $TURBO_ARGS; then
    echo "${RED}Pre-push checks failed!${NC}"
    echo "Fix the issues before pushing, or use: git push --no-verify"
    exit 1
fi

# 7. Run test file type checking (BLOCKING - catches test type errors)
echo "Running test file type checking..."
# shellcheck disable=SC2086
if ! pnpm turbo run typecheck:spec $TURBO_FILTER $TURBO_ARGS; then
    echo "${RED}Test file type checking failed!${NC}"
    echo "Fix the type errors before pushing, or use: git push --no-verify"
    exit 1
fi

# 8. Run copy-paste detection (warning only - doesn't block push)
# Note: jscpd consoleFull reporter generates ~4000 lines of output for all clones.
# Capture output to prevent pipe/OOM issues in constrained environments (Steam Deck).
echo "Running copy-paste detection..."
CPD_OUTPUT=$(pnpm cpd 2>&1) || true
CPD_SUMMARY=$(echo "$CPD_OUTPUT" | grep -E "Found [0-9]+ clones|duplicated lines" | head -2)
if [ -n "$CPD_SUMMARY" ]; then
    echo "${YELLOW}⚠️  $CPD_SUMMARY${NC}"
    echo "Run 'pnpm cpd:report' for detailed HTML report"
else
    echo "Copy-paste detection completed."
fi

# 9. Run duplicate-export name check (BLOCKING)
# Catches export-name collisions across two packages or two files within a
# package. CI runs this in the lint job; running it here too closes the
# local-vs-CI gap. Fast (~300ms) — negligible cost vs a CI round-trip.
# Workflow-sync guard: a workflow change reaching develop first silently
# disables claude-review on every PR until the next release. Skips itself
# on main-cut branches (the sanctioned path). Fast (a couple of git calls).
echo "Running workflow-sync guard..."
if ! pnpm ops guard:workflow-sync; then
    echo "${RED}Workflow-sync guard failed!${NC}"
    echo "Route .github/workflows/ changes through a main-cut PR (see tzurot-git-workflow skill)"
    exit 1
fi

echo "Running duplicate-export name check..."
if ! pnpm ops guard:duplicate-exports; then
    echo "${RED}Duplicate export name check failed!${NC}"
    echo "Either rename the duplicates or add them to ALLOWLIST in check-duplicate-exports.ts"
    exit 1
fi

# 10. Run dead-file check (BLOCKING)
# `pnpm knip:dead` flags source files whose only references are their own
# colocated tests — i.e., production code with zero live consumers. CI runs
# this in the lint job; mirroring it here catches dead code before push,
# saving a CI round-trip. Fast (~5s).
echo "Running dead-file check..."
if ! pnpm knip:dead; then
    echo "${RED}Dead-file check failed!${NC}"
    echo "Either remove the dead file(s), or wire up production consumers."
    echo "If knip:dead's basename matcher reports a false positive, verify"
    echo "the file is actually reachable via 'grep -rln <filename> services/ packages/'."
    exit 1
fi

# 11. Run dependency boundary checks (BLOCKING)
# Clear the depcruise cache first — content-strategy caching has missed
# circular-dependency violations across renamed/moved files at least once
# (PR #901, 2026-04-25). The full analysis takes ~5s, so the cost of always
# starting cold is negligible compared to the cost of a stale "no violations".
echo "Running dependency boundary checks..."
# Path must match .dependency-cruiser.cjs `cache.folder`
rm -rf node_modules/.cache/dependency-cruiser
if ! pnpm depcruise; then
    echo "${RED}Dependency boundary check failed!${NC}"
    echo "Run 'pnpm depcruise' for details"
    exit 1
fi

# 12. Run Python quality checks if Python files changed
if [ -n "$PYTHON_FILES" ]; then
    echo "Running Python quality checks (ruff + mypy + pytest)..."
    if ! (cd services/voice-engine && ruff check .); then
        echo "${RED}Python linting (ruff) failed!${NC}"
        exit 1
    fi
    if ! (cd services/voice-engine && mypy --strict server.py tests/); then
        echo "${RED}Python type checking (mypy) failed!${NC}"
        exit 1
    fi
    # Pytest was previously missing from this hook — tests would fail in CI
    # after a successful push. Added 2026-04-19 after CI caught a hermeticity
    # leak in test_openai_compat.py that passed locally (real ffmpeg available)
    # but failed in CI (no ffmpeg → WAV fallback broke content-type assertion).
    if ! (cd services/voice-engine && python3 -m pytest tests/ -q); then
        echo "${RED}Python tests (pytest) failed!${NC}"
        exit 1
    fi
fi

echo "${GREEN}All pre-push checks passed!${NC}"
