{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "references": [
    {
      "path": "../packages/common-types"
    },
    {
      "path": "../packages/embeddings"
    }
  ],
  "include": [
    "src/**/*.ts",
    "testing/**/*.ts",
    "debug/**/*.ts",
    "migrations/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
